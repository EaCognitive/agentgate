# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

# AgentGate API Configuration
AGENTGATE_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Optional external identity provider redirects
NEXT_PUBLIC_DESCOPE_SIGNIN_URL=
NEXT_PUBLIC_DESCOPE_SIGNUP_URL=

# Docs binder API reference target (used by /docs/api redirect)
# Set to your deployed backend Scalar endpoint in production
DOCS_API_REFERENCE_URL=http://localhost:8000/docs

# Optional: Database URL for sessions (if using database adapter)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentgate

# ============================================================================
# Playground Configuration
# ============================================================================

# OpenAI API Key - REQUIRED for Playground functionality
# Get your key from: https://platform.openai.com/api-keys
# Without this key, the playground will show "I'm currently unable to process your request"
#
# SECURITY WARNING: Never commit this file with real keys
# For production, use environment-specific secrets management
OPENAI_API_KEY=sk-proj-your-key-here

# Alternative: Set via environment variable
# export OPENAI_API_KEY=sk-proj-your-key-here

# Optional: OAuth Provider Credentials
# GITHUB_ID=your-github-id
# GITHUB_SECRET=your-github-secret
# GOOGLE_ID=your-google-id
# GOOGLE_SECRET=your-google-secret
