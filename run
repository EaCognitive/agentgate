}

cmd_migrate() {
    local python_bin="python3"
    if [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
        python_bin="$SCRIPT_DIR/.venv/bin/python"
    fi

    local action="${1:-current}"
    if [[ $# -gt 0 ]]; then
        shift
    fi

    case "$action" in
        up)
            "$python_bin" -m alembic upgrade head
            ;;
        down)
            local target="${1:--1}"
            "$python_bin" -m alembic downgrade "$target"
            ;;
        current)
            "$python_bin" -m alembic current
            ;;
        history)
            "$python_bin" -m alembic history --verbose
            ;;
        heads)
            "$python_bin" -m alembic heads
            ;;
        create)
            local message="${1:-}"
            if [[ -z "$message" ]]; then
                err "Migration message required: ./run migrate create \"description\""
                return 1
            fi
            "$python_bin" -m alembic revision --autogenerate -m "$message"
            ;;
        *)
            err "Unknown migrate action: $action"
            muted "Valid actions: up, down [target], current, history, heads, create <message>"
            return 1
            ;;
    esac
}

is_truthy() {
    local raw="${1:-}"
    local value
    value=$(echo "$raw" | tr '[:upper:]' '[:lower:]')
    case "$value" in
        1|true|yes|on)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_psycopg_driver() {
    local python_bin="python3"
    if [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
        python_bin="$SCRIPT_DIR/.venv/bin/python"
    fi

    if "$python_bin" -c "import psycopg" >/dev/null 2>&1; then
        return 0
    fi

    if ! command -v uv >/dev/null 2>&1; then
        err "psycopg is required for PostgreSQL cutover simulation."
        muted "Install uv or preinstall psycopg in the active Python environment."
        return 1
    fi

    info "Installing psycopg driver in project environment..."
    uv pip install --python "$python_bin" "psycopg[binary]>=3.2.0"
}

wait_for_local_cutover_postgres() {
    info "Ensuring local PostgreSQL test container is ready..."
    if ! docker compose --profile test up -d db-test >/dev/null 2>&1; then
        err "Unable to start db-test container for cutover simulation."
        return 1
    fi

    local attempt=0
    local max_attempts=45
    while [[ $attempt -lt $max_attempts ]]; do
        if docker compose --profile test exec -T db-test pg_isready -U test >/dev/null 2>&1; then
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 1
    done

    err "db-test container did not become ready in time."
    return 1
}

check_cloud_postgres_connectivity() {
    local db_url="$1"
    local python_bin="python3"
    if [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
        python_bin="$SCRIPT_DIR/.venv/bin/python"
    fi

    "$python_bin" - "$db_url" <<'PY'
import sys
import psycopg

url = sys.argv[1].replace("postgresql+psycopg://", "postgresql://", 1)
with psycopg.connect(url, connect_timeout=5) as conn:
    with conn.cursor() as cursor:
        cursor.execute("SELECT 1")
        cursor.fetchone()
PY
}

run_cutover_smoke_attempt() {
    local backend="$1"
    local db_url="$2"
    local allow_cloud="$3"
    shift 3
    local -a test_args=("$@")
    local -a cmd=(
        "$SCRIPT_DIR/test"
        --no-parallel
        --no-open
        tests/integration/test_identity_cutover.py
    )
    if [[ ${#test_args[@]} -gt 0 ]]; then
        cmd+=("${test_args[@]}")
    fi

    case "$backend" in
        sqlite)
            info "Cutover smoke backend: sqlite (local fallback)"
            env CUTOVER_TEST_BACKEND=sqlite "${cmd[@]}"
            ;;
        postgres-local)
            if ! command -v docker >/dev/null 2>&1; then
                err "Docker is unavailable for postgres-local cutover backend."
                return 1
            fi
            if ! docker info >/dev/null 2>&1; then
                err "Docker daemon is not running for postgres-local cutover backend."
                return 1
            fi
            ensure_psycopg_driver || return 1
            wait_for_local_cutover_postgres || return 1
            info "Cutover smoke backend: postgres-local (docker profile test db)"
            env \
                CUTOVER_TEST_BACKEND=postgres \
                CUTOVER_TEST_REQUIRE_POSTGRES=true \
                "${cmd[@]}"
            ;;
        postgres-cloud)
            if [[ -z "$db_url" ]]; then
                err "postgres-cloud backend requires a database URL."
                muted "Set CUTOVER_TEST_DATABASE_URL or pass --db-url."
                return 1
            fi
            if ! is_truthy "$allow_cloud"; then
                err "Cloud cutover backend is locked by default."
                muted "Pass --allow-cloud or set CUTOVER_TEST_ALLOW_CLOUD=true."
                return 1
            fi
            ensure_psycopg_driver || return 1
            if ! check_cloud_postgres_connectivity "$db_url" >/dev/null 2>&1; then
                err "Cloud PostgreSQL connectivity check failed."
                return 1
            fi
            info "Cutover smoke backend: postgres-cloud (explicit external database)"
            env \
                CUTOVER_TEST_BACKEND=postgres \
                CUTOVER_TEST_REQUIRE_POSTGRES=true \
                CUTOVER_TEST_DATABASE_URL="$db_url" \
                "${cmd[@]}"
            ;;
        *)
            err "Unsupported cutover backend: $backend"
            return 1
            ;;
    esac
}

cmd_cutover() {
    local scenario="${1:-smoke}"
    if [[ $# -gt 0 ]]; then
        shift
    fi

    if [[ "$scenario" == "descope-setup" ]]; then
        local python_bin="python3"
        if [[ -f "$SCRIPT_DIR/.venv/bin/python" ]]; then
            python_bin="$SCRIPT_DIR/.venv/bin/python"
        fi
        local setup_script="$SCRIPT_DIR/scripts/setup_descope_provider.py"
        if [[ ! -f "$setup_script" ]]; then
            err "Descope setup helper not found: $setup_script"
            return 1
        fi
        info "Running Descope setup helper..."
        "$python_bin" "$setup_script" "$@"
        return $?
    fi

    if [[ "$scenario" != "smoke" ]]; then
        err "Unknown cutover scenario: $scenario"
        muted "Usage: ./run cutover smoke [--backend ...] [--launch ...] [--db-url ...]"
        muted "       ./run cutover descope-setup --project-id <id> [--dry-run]"
        return 1
    fi

    local backend="${CUTOVER_SMOKE_BACKEND:-auto}"
    local launch="${CUTOVER_SMOKE_LAUNCH:-auto}"
    local db_url="${CUTOVER_TEST_DATABASE_URL:-}"
    local allow_cloud="${CUTOVER_TEST_ALLOW_CLOUD:-false}"
    local no_fallback=false
    local -a passthrough=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backend)
                if [[ $# -lt 2 ]]; then
                    err "--backend requires a value."
                    return 1
                fi
                backend="$2"
                shift 2
                ;;
            --launch)
                if [[ $# -lt 2 ]]; then
                    err "--launch requires a value."
                    return 1
                fi
                launch="$2"
                shift 2
                ;;
            --db-url)
                if [[ $# -lt 2 ]]; then
                    err "--db-url requires a value."
                    return 1
                fi
                db_url="$2"
                shift 2
                ;;
            --allow-cloud)
                allow_cloud=true
                shift
                ;;
            --no-fallback)
                no_fallback=true
                shift
                ;;
            --)
                shift
                passthrough=("$@")
                break
                ;;
            *)
                passthrough+=("$1")
                shift
                ;;
        esac
    done

    backend=$(echo "$backend" | tr '[:upper:]' '[:lower:]')
    launch=$(echo "$launch" | tr '[:upper:]' '[:lower:]')

    case "$backend" in
        auto|sqlite|postgres-local|postgres-cloud)
            ;;
        *)
            err "Invalid --backend value: $backend"
            muted "Valid values: auto, sqlite, postgres-local, postgres-cloud"
            return 1
            ;;
    esac

    case "$launch" in
        auto|local|cloud)
            ;;
        *)
            err "Invalid --launch value: $launch"
            muted "Valid values: auto, local, cloud"
            return 1
            ;;
    esac

    local runtime_env="${AGENTGATE_ENV:-development}"
    runtime_env=$(echo "$runtime_env" | tr '[:upper:]' '[:lower:]')

    local allow_sqlite_fallback=true
    if [[ "$runtime_env" == "staging" || "$runtime_env" == "production" ]]; then
        allow_sqlite_fallback=false
    fi
    if is_truthy "${CUTOVER_ALLOW_SQLITE_FALLBACK:-}"; then
        allow_sqlite_fallback=true
    fi

    local -a attempts=()
    if [[ "$backend" != "auto" ]]; then
        attempts=("$backend")
    else
        case "$launch" in
            local)
                attempts=("postgres-local")
                ;;
            cloud)
                attempts=("postgres-cloud" "postgres-local")
                ;;
            auto)
                if [[ -n "$db_url" ]]; then
                    attempts=("postgres-cloud" "postgres-local")
                elif [[ "$runtime_env" == "staging" || "$runtime_env" == "production" ]]; then
                    attempts=("postgres-local")
                else
                    attempts=("postgres-local")
                fi
                ;;
        esac
        if $allow_sqlite_fallback; then
            attempts+=("sqlite")
        fi
    fi

    if $no_fallback && [[ ${#attempts[@]} -gt 1 ]]; then
        attempts=("${attempts[0]}")
    fi

    info "Running identity cutover smoke scenario..."
    muted "Launch mode: $launch"
    muted "Backend strategy: ${attempts[*]}"
    muted "This command runs integration tests only. It does not launch dashboard/API."
    muted "For a clean runtime launch use: ./run demo --fresh"
    if [[ -n "$db_url" ]]; then
        muted "Cloud database URL provided via explicit override"
    fi
    echo ""

    local attempt
    local success_backend=""
    for attempt in "${attempts[@]}"; do
        if run_cutover_smoke_attempt "$attempt" "$db_url" "$allow_cloud" "${passthrough[@]}"; then
            success_backend="$attempt"
            break
        fi
        warn "Cutover smoke failed on backend '$attempt'."
        if $no_fallback; then
            break
        fi
        muted "Attempting next fallback backend..."
        echo ""
    done

    if [[ -z "$success_backend" ]]; then
        err "Cutover smoke scenario failed for all configured backends."
        return 1
    fi

    info "Cutover smoke scenario passed on backend: $success_backend"
}

cmd_clean() {
    local wipe_data=false
    if [[ "${1:-}" == "--wipe-data" ]]; then
        wipe_data=true
    fi

    if $wipe_data; then
        record_container_event "clean" "start" "clean --wipe-data requested"
        if ! confirm_action "This will remove containers, VOLUMES, and caches. Continue?"; then
            muted "Aborted."
            return 0
        fi
    else
        record_container_event "clean" "start" "clean requested"
        if ! confirm_action "This will remove containers and caches (volumes preserved). Continue?"; then
            muted "Aborted."
            return 0
        fi
    fi

    echo ""
    info "Stopping and removing containers..."
    if $wipe_data; then
        docker compose down -v --remove-orphans 2>/dev/null || true
        docker compose --profile test down -v --remove-orphans 2>/dev/null || true
        local project_name
        project_name="$(compose_project_name)"
        local lingering_volumes
        lingering_volumes=$(docker volume ls -q --filter "label=com.docker.compose.project=$project_name" || true)
        if [[ -n "$lingering_volumes" ]]; then
            echo "$lingering_volumes" | xargs -r docker volume rm -f >/dev/null 2>&1 || true
        fi
    else
        docker compose down --remove-orphans 2>/dev/null || true
        docker compose --profile test down --remove-orphans 2>/dev/null || true
    fi

    info "Clearing Python caches..."
    find "$SCRIPT_DIR" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    find "$SCRIPT_DIR" -type d -name ".pytest_cache" -exec rm -rf {} + 2>/dev/null || true
    rm -rf "$SCRIPT_DIR/.ruff_cache" 2>/dev/null || true

    info "Clearing Next.js cache..."
    rm -rf "$SCRIPT_DIR/dashboard/.next" 2>/dev/null || true
    rm -rf "$SCRIPT_DIR/dashboard/node_modules/.cache" 2>/dev/null || true

    echo ""
    if $wipe_data; then
        warn "Volumes removed. Database and server state were reset."
        record_container_event "clean" "completed" "clean --wipe-data completed"
    else
        info "Clean complete (volumes preserved)."
        muted "Run './run clean --wipe-data' only for intentional full reset."
        record_container_event "clean" "completed" "clean completed volumes preserved"
    fi
}

cmd_stop() {
    record_container_event "stop" "start" "stop command requested"
    info "Stopping containers (preserving volumes)..."
    docker compose down --remove-orphans 2>/dev/null || true
    docker compose --profile test down --remove-orphans 2>/dev/null || true
    info "Services stopped."
    muted "User credentials and state are preserved in Docker volumes."
    record_container_event "stop" "completed" "services stopped volumes preserved"
}

resolve_ea_agentgate_cli() {
    if [[ -x "$SCRIPT_DIR/.venv/bin/ea-agentgate" ]]; then
        echo "$SCRIPT_DIR/.venv/bin/ea-agentgate"
        return 0
    fi
    if command -v ea-agentgate >/dev/null 2>&1; then
        command -v ea-agentgate
        return 0
    fi
    return 1
}

cmd_ops() {
    local cli_path
    if ! cli_path=$(resolve_ea_agentgate_cli); then
        err "ea-agentgate CLI not found. Install dependencies first."
        muted "Run: uv sync --extra dev --extra server"
        return 1
    fi

    if [[ $# -eq 0 ]]; then
        exec "$cli_path" --help
    fi

    exec "$cli_path" "$@"
}

cmd_gate() {
    local mode="full"
    if [[ $# -gt 0 ]] && [[ "$1" == "full" || "$1" == "infra" || "$1" == "lint" || "$1" == "test" ]]; then
        mode="$1"
        shift
    fi

    case "$mode" in
        full)
            info "Running chronological quality gate (phase 1 -> phase 2 -> phase 3)"
            echo ""

            if ! cmd_infra_audit; then
                return 1
            fi

            echo ""
            info "Phase 2: Style and structure audit"
            echo ""
            if ! cmd_lint; then
                return 1
            fi

            echo ""
            info "Phase 3: Test execution"
            echo ""
            cmd_test --no-open "$@"

            local run_preprod_gate=false
            if [[ "${MCP_PREPROD_GATE:-false}" == "true" ]]; then
                run_preprod_gate=true
            fi
            if [[ "${AGENTGATE_ENV:-development}" == "staging" || "${AGENTGATE_ENV:-development}" == "production" ]]; then
                run_preprod_gate=true
            fi

            if $run_preprod_gate; then
                echo ""
                info "Phase 4: MCP pre-production policy-governance validation"
                echo ""
                if ! cmd_preprod_mcp_gate; then
                    return 1
                fi
            else
                warn "Skipping MCP pre-production gate in development profile."
                muted "Set MCP_PREPROD_GATE=true to enforce local pre-production validation."
            fi
            ;;
        infra)
            cmd_infra_audit
            ;;
        lint)
            cmd_lint
            ;;
        test)
            cmd_test --no-open "$@"
            ;;
        *)
            err "Unknown gate mode: $mode"
            muted "Valid modes: full, infra, lint, test"
            return 1
            ;;
    esac
}

cmd_seed() {
    warn "Credential seeding is disabled."
    info "Initial credentials must be created via browser onboarding."
    muted "Open: http://localhost:3000/setup"
    open_url "http://localhost:3000/setup"
}

check_service() {
    # Returns: "healthy", "running", "port-conflict", or "offline"
    local name="$1" port="$2" docker_svc="$3"
    local docker_running=false
    local compose_ps_output

    # Check if this project's docker compose service is running
    compose_ps_output="$(docker compose ps --status running 2>/dev/null || true)"
    if [[ "$compose_ps_output" == *"$docker_svc"* ]]; then
        docker_running=true
    fi

    case "$name" in
        "API Server")
            # Verify the health endpoint returns AgentGate's signature
            local body
            body=$(curl -sf "http://localhost:${port}/api/health" 2>/dev/null || true)
            if [[ -n "$body" ]] && echo "$body" | grep -q '"status"'; then
                if $docker_running; then
                    echo "healthy (docker)"
                else
                    # Port has our API but not via docker -- local dev
                    echo "healthy (local)"
                fi
                return
            fi
            # Something else is on the port
            if curl -sf "http://localhost:${port}" &>/dev/null; then
                echo "port conflict"
                return
            fi
            ;;
        "Dashboard")
            if $docker_running; then
                echo "healthy (docker)"
                return
            fi
            # For local dev, check if next dev is the process on port 3000
            if lsof -iTCP:"$port" -sTCP:LISTEN 2>/dev/null \
                | grep -q node; then
                echo "healthy (local)"
                return
            fi
            if curl -sf "http://localhost:${port}" &>/dev/null; then
                echo "port conflict"
                return
            fi
            ;;
        "PostgreSQL")
            if $docker_running; then
                echo "running (docker)"
                return
            fi
            ;;
        "Redis")
            if $docker_running; then
                echo "running (docker)"
                return
            fi
            # Check if redis-cli ping works and it's local redis
            if command -v redis-cli &>/dev/null; then
                if redis-cli -p "$port" ping 2>/dev/null | grep -q PONG; then
                    echo "running (local)"
                    return
                fi
            fi
            ;;
    esac

    echo "offline"
}

cmd_status() {
    local fmt="%-14s %-8s %s\n"

    # Collect statuses
    local api_status dash_status pg_status redis_status
    api_status=$(check_service "API Server" 8000 "server")
    dash_status=$(check_service "Dashboard" 3000 "dashboard")
    pg_status=$(check_service "PostgreSQL" 5432 "db")
    redis_status=$(check_service "Redis" 6379 "redis")

    if $HAS_GUM; then
        local lines=()
        lines+=("SERVICE        PORT     STATUS")
        lines+=("-------------- -------- ----------------")
        lines+=("$(printf "$fmt" "API Server" "8000" "$api_status")")
        lines+=("$(printf "$fmt" "Dashboard" "3000" "$dash_status")")
        lines+=("$(printf "$fmt" "PostgreSQL" "5432" "$pg_status")")
        lines+=("$(printf "$fmt" "Redis" "6379" "$redis_status")")

        printf '%s\n' "${lines[@]}" | gum style \
            --border rounded \
            --border-foreground "$C_BORDER" \
            --foreground "$C_TEXT" \
            --padding "1 2" \
            --margin "0 2"
    else
        echo ""
        printf "  ${BOLD}$fmt${RESET}" "SERVICE" "PORT" "STATUS"
        echo "  -------------- -------- ----------------"

        local name status color
        for pair in "API Server:$api_status" \
                    "Dashboard:$dash_status" \
                    "PostgreSQL:$pg_status" \
                    "Redis:$redis_status"; do
            name="${pair%%:*}"
            status="${pair#*:}"
            color="$RED"
            if [[ "$status" == healthy* || "$status" == running* ]]; then
                color="$GREEN"
            elif [[ "$status" == "port conflict" ]]; then
                color="$YELLOW"
            fi
            local port_map
            case "$name" in
                "API Server") port_map="8000" ;;
                "Dashboard")  port_map="3000" ;;
                "PostgreSQL") port_map="5432" ;;
                "Redis")      port_map="6379" ;;
            esac
            printf "  $fmt" "$name" "$port_map" \
                "$(echo -e "${color}${status}${RESET}")"
        done
    fi

    echo ""

    # Docker compose status -- only show if containers are actually running
    local compose_out
    compose_out=$(docker compose ps 2>/dev/null || true)
    if echo "$compose_out" | tail -n +2 | grep -q .; then
        muted "Docker Compose containers:"
        echo ""
        echo "$compose_out"
    fi
}

cmd_logs() {
    docker compose logs -f "$@"
}

