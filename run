cmd_menu() {
    local choice
    if $HAS_GUM; then
        choice=$(gum choose \
            --cursor.foreground "$C_PRIMARY" \
            --selected.foreground "$C_PRIMARY" \
            --header "Select a command:" \
            --header.foreground "$C_TEXT" \
            "demo      - Full stack with Docker" \
            "dev       - Local development servers" \
            "gate      - Chronological quality gate" \
            "stop      - Stop Docker services (preserve data)" \
            "test      - Run test suite" \
            "cutover   - Identity cutover + Descope setup helper" \
            "verify    - Formal verification tools (chaos/latest/report)" \
            "lint      - Lint and type checks" \
            "docs-check - Build docs bundle and governance checks" \
            "migrate   - Alembic migration helpers" \
            "status    - Show service status" \
            "seed      - Configure admin user" \
            "logs      - Tail Docker logs" \
            "clean     - Remove containers and caches" \
            "clean-wipe-data - Full destructive reset" \
            "help      - Show all commands")
        # Extract command name (first word before spaces)
        choice="${choice%% *}"
        choice="$(echo "$choice" | tr -d '[:space:]')"
    else
        echo -e "  ${BOLD}Select a command:${RESET}"
        echo ""
        echo "    1) demo      - Full stack with Docker"
        echo "    2) dev       - Local development servers"
        echo "    3) gate      - Chronological quality gate"
        echo "    4) stop      - Stop Docker services (preserve data)"
        echo "    5) test      - Run test suite"
        echo "    6) cutover   - Identity cutover + Descope setup helper"
        echo "    7) verify    - Formal verification tools (chaos/latest/report)"
        echo "    8) lint      - Lint and type checks"
        echo "    9) docs-check - Build docs bundle and governance checks"
        echo "   10) migrate   - Alembic migration helpers"
        echo "   11) status    - Show service status"
        echo "   12) seed      - Configure admin user"
        echo "   13) logs      - Tail Docker logs"
        echo "   14) clean     - Remove containers and caches"
        echo "   15) clean --wipe-data - Full destructive reset"
        echo "   16) help      - Show all commands"
        echo ""
        echo -en "  ${GREEN}Enter choice [1-16]: ${RESET}"
        read -r num
        case "$num" in
            1) choice="demo" ;;
            2) choice="dev" ;;
            3) choice="gate" ;;
            4) choice="stop" ;;
            5) choice="test" ;;
            6) choice="cutover" ;;
            7) choice="verify" ;;
            8) choice="lint" ;;
            9) choice="docs-check" ;;
            10) choice="migrate" ;;
            11) choice="status" ;;
            12) choice="seed" ;;
            13) choice="logs" ;;
            14) choice="clean" ;;
            15) choice="clean-wipe-data" ;;
            16) choice="help" ;;
            *)
                err "Invalid choice."
                return 1
                ;;
        esac
    fi

    echo ""

    case "$choice" in
        demo)   cmd_demo "$@" ;;
        dev)    cmd_dev ;;
        gate)   cmd_gate full ;;
        stop)   cmd_stop ;;
        test)   cmd_test ;;
        cutover) cmd_cutover smoke ;;
        verify) cmd_verify latest ;;
        lint)   cmd_lint ;;
        docs-check) cmd_docs_check ;;
        migrate) cmd_migrate current ;;
        status) cmd_status ;;
        seed)   cmd_seed ;;
        logs)   cmd_logs ;;
        clean)  cmd_clean ;;
        clean-wipe-data) cmd_clean --wipe-data ;;
        help)   cmd_help ;;
        *)
            err "Unknown command: $choice"
            return 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Gum install hint
# ---------------------------------------------------------------------------
suggest_gum() {
    if ! $HAS_GUM; then
        muted "Tip: Install gum for a better experience:"
        muted "  brew install gum    (macOS)"
        muted "  https://github.com/charmbracelet/gum"
        echo ""
    fi
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
main() {
    local cmd="${1:-}"

    if [[ -n "$cmd" ]]; then
        shift
    fi

    # Show banner and run env setup once, up front
    banner
    setup_env

    case "$cmd" in
        demo)   cmd_demo "$@" ;;
        dev)    cmd_dev ;;
        gate)   cmd_gate "$@" ;;
        stop)   cmd_stop ;;
        test)   cmd_test "$@" ;;
        cutover) cmd_cutover "$@" ;;
        verify) cmd_verify "$@" ;;
        lint)   cmd_lint ;;
        docs-check) cmd_docs_check ;;
        migrate) cmd_migrate "$@" ;;
        clean)  cmd_clean "$@" ;;
        seed)   cmd_seed ;;
        status) cmd_status ;;
        logs)   cmd_logs "$@" ;;
        ops)    cmd_ops "$@" ;;
        help|--help|-h)
            cmd_help
            suggest_gum
            ;;
        "")
            suggest_gum
            cmd_menu
            ;;
        *)
            err "Unknown command: $cmd"
            echo ""
            cmd_help
            return 1
            ;;
    esac
}

main "$@"
