        echo "    ./run verify formal chaos single"
        echo "    ./run verify formal chaos parallel"
        echo "    ./run verify formal chaos custom --count 150k --workers 8 --seed 77 --enforce-runtime"
        echo "    ./run verify formal run --count 100k --workers 6 --enforce-runtime"
