        echo "    gate      Chronological quality gate (infra -> lint -> test)"
        echo "    stop      Stop docker services and preserve all volumes"
        echo "    test      Run test suite (delegates to ./test)"
        echo "    cutover   Identity cutover workflows (smoke + descope setup helper)"
        echo "    verify    Formal verification utilities (chaos/latest/history/run/scrub/organize/report)"
        echo "    lint      Run ruff + pylint + dashboard build check"
        echo "    docs-check Build docs bundle + enforce docs governance"
        echo "    migrate   Alembic migration helpers (up/down/current/history/heads/create)"
        echo "    clean     Remove containers/caches (volumes preserved)"
        echo "    clean --wipe-data  Full reset: remove volumes and caches"
        echo "    seed      Open browser onboarding (/setup)"
        echo "    status    Show running services, ports, and health"
        echo "    logs      Tail docker compose logs"
        echo "    ops       Run ea-agentgate CLI via ./run ops <args>"
        echo "    help      Show this help message"
        echo ""
        echo -e "  ${BOLD}OPERATIONS EXAMPLES (single entry: ./run)${RESET}"
        echo "    ./run ops login"
        echo "    ./run ops overview"
        echo "    ./run ops threats list"
