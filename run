        gum style \
            --foreground "$C_TEXT" \
            --padding "0 2" \
            --margin "0 2" \
            "USAGE" \
            "  ./run [command] [args]" \
            "" \
            "INFRASTRUCTURE" \
            "  demo      Full stack: docker compose + health checks + open browser" \
            "            Options: --fresh|--from-zero, --no-open" \
            "  dev       Local dev: uvicorn --reload + next dev (no Docker)" \
            "  gate      Chronological quality gate (infra -> lint -> test)" \
            "  stop      Stop docker services and preserve all volumes" \
            "  test      Run test suite (delegates to ./test)" \
            "  cutover   Identity cutover workflows (smoke + descope setup helper)" \
            "  verify    Formal verification utilities (chaos/latest/history/run/scrub/organize/report)" \
